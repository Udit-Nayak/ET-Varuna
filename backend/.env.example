PORT=5000
CLIENT_ORIGIN=http://localhost:5173
MONGODB_URI=mongodb://127.0.0.1:27017/gria

HF_TOKEN=your_huggingface_token
HF_MODEL_ID=meta-llama/Llama-3.1-8B-Instruct
HF_API_BASE_URL=https://api-inference.huggingface.co/models
HF_TIMEOUT_MS=30000
HF_MAX_RETRIES=2

NEWSAPI_KEY=your_newsapi_key
NEWSAPI_BASE_URL=https://newsapi.org/v2/everything
GRIA_NEWS_CRON_MINUTES=35
GRIA_REFRESH_ON_STARTUP=true
GRIA_ENABLE_GDELT=false
GRIA_ENABLED_SOURCES=newsapi-energy-geopolitics,mea-india,marinelink
GRIA_INCLUDE_DIRECT_RSS=false
GRIA_INCLUDE_SECONDARY_RSS=false
GRIA_INCLUDE_GOVERNMENT_RSS=false
GRIA_INCLUDE_SECONDARY_MARITIME_RSS=false
GRIA_DEFAULT_LOOKBACK_HOURS=24
GRIA_DEDUPE_WINDOW_DAYS=14
GRIA_VECTOR_INDEX_NAME=griaVectorIndex
GRIA_VECTOR_DIMENSIONS=384
GRIA_VECTOR_CHUNK_WORDS=180
GRIA_VECTOR_CHUNK_OVERLAP_WORDS=35
GRIA_EMBEDDING_PROVIDER=local
GEMINI_EMBEDDING_MODEL=text-embedding-004
GRIA_RERANK_PROVIDER=local

GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

AISSTREAM_API_KEY=your_aisstream_api_key
AIS_SIMULATION_ENABLED=false
